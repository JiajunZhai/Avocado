# ==========================================
# 云端高精模型配置 (DeepSeek)
# ==========================================
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# DeepSeek 官方 API 终点
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# 模型选择:
# deepseek-chat (V3): 速度快，逻辑强，适合日常生成
# deepseek-reasoner (R1): 强逻辑推理，适合深层心理学拆解
DEEPSEEK_MODEL="deepseek-chat"

# 单次调用最大等待秒数（draft 90s / director 120s 默认）
DEEPSEEK_TIMEOUT_SECONDS="120"

# （可选）DeepSeek 成本估算价格（元 / 1K token）
# DEEPSEEK_PRICE_PROMPT_CNY_PER_1K="0.001"
# DEEPSEEK_PRICE_COMPLETION_CNY_PER_1K="0.002"

# ==========================================
# Phase 25 / 多模型支持 — 均遵循 OpenAI 兼容协议
# 只需为要启用的厂商配置 API Key 即可，Base URL/Model 留空走默认
# ==========================================
#
# Phase 27 / F 之后，API Key / Base URL / 默认模型 / 自定义模型列表
# 也可以直接在前端「LLM Providers」页面保存到 SQLite（明文存储在
# backend/data/app.sqlite3，请妥善保管）。
# 优先级：call-arg > DB > env > 内置默认，所以 .env 值仍然保留为
# 无 UI 场景（CI / 批处理）的回落。

# --- SiliconFlow 硅基流动 (https://siliconflow.cn) ---
# SILICONFLOW_API_KEY="sk-..."
# SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
# SILICONFLOW_MODEL="deepseek-ai/DeepSeek-V3"
# SILICONFLOW_PRICE_PROMPT_CNY_PER_1K="0.001"
# SILICONFLOW_PRICE_COMPLETION_CNY_PER_1K="0.002"

# --- 阿里云百炼 (DashScope 兼容模式) ---
# BAILIAN_API_KEY="sk-..."
# BAILIAN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# BAILIAN_MODEL="qwen-plus"
# BAILIAN_PRICE_PROMPT_CNY_PER_1K="0.0008"
# BAILIAN_PRICE_COMPLETION_CNY_PER_1K="0.002"

# --- OpenRouter (https://openrouter.ai) ---
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_MODEL="deepseek/deepseek-chat"
# OPENROUTER_PRICE_PROMPT_CNY_PER_1K="0.002"
# OPENROUTER_PRICE_COMPLETION_CNY_PER_1K="0.006"

# --- Open Code ZEN (deferred, 占位配置) ---
# ZEN_API_KEY=""
# ZEN_BASE_URL="https://api.opencode.zen/v1"
# ZEN_MODEL="zen-default"

# ==========================================
# Phase 26 / E — SQLite 运行期存储 + 混合检索
# ==========================================

# SQLite 数据库路径（projects / history_log / factors / compliance_rules /
# knowledge_docs / knowledge_fts / knowledge_vectors 都写在这里）。
# 留空默认 backend/data/app.sqlite3（WAL 模式 + FTS5）。
# DB_PATH="backend/data/app.sqlite3"

# RAG 检索栈开关：
#   auto  —— 自动判定（默认）。检测到 sentence-transformers 即走 hybrid；否则回退 TF-IDF。
#   hybrid —— 强制启用 BM25(FTS5) + Vector + RRF + MMR。
#   tfidf  —— 仅使用 TF-IDF，CI 环境推荐。
# RAG_RETRIEVAL="auto"

# Embedding 模型 ID（首次 retrieve 时懒加载，不占用启动时间）
# RAG_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# 混合检索各阶段参数
# RAG_TOPN="30"                 # 每个子召回器（BM25 / Vector / TF-IDF）候选池大小
# RAG_RRF_K="60"                # Reciprocal Rank Fusion 常数（越大越弱化排名差）
# RAG_MMR_LAMBDA="0.7"          # MMR 相关性 vs 多样性权衡，0.0=纯多样，0.99=纯相关

# （可选）Cross-Encoder 重排：默认 off，打开后在 top-k 上再跑一次更贵的相关性模型
# RAG_RERANK="off"
# RAG_RERANK_MODEL="cross-encoder/ms-marco-MiniLM-L-6-v2"
